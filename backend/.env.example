# IP-Chain Backend Environment Variables

# Database
DATABASE_URL=sqlite:///./ipchain/ipchain.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/ipchain

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# IPFS - Pinata (recommended)
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# IPFS - Local node (fallback)
LOCAL_IPFS_URL=http://127.0.0.1:5001

# Blockchain (Ethereum / Polygon / Ganache)
RPC_URL=http://127.0.0.1:7545
CHAIN_ID=1337
CONTRACT_ADDRESS=
CONTRACT_ABI_PATH=
