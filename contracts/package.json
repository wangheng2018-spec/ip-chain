{
  "name": "ip-chain-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "npx hardhat compile",
    "deploy:mumbai": "npx hardhat run scripts/deploy.js --network polygon_mumbai",
    "deploy:polygon": "npx hardhat run scripts/deploy.js --network polygon",
    "verify:mumbai": "npx hardhat verify --network polygon_mumbai",
    "verify:polygon": "npx hardhat verify --network polygon"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1"
  }
}