# === Storage ===
# Local IPFS node (recommended - free, no signup needed)
# Install: apt install ipfs && ipfs init && ipfs daemon
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY=http://127.0.0.1:8080

# Pinata IPFS (alternative if you want cloud IPFS)
# PINATA_API_KEY=your_pinata_key
# PINATA_SECRET_API_KEY=your_pinata_secret

# Web3.Storage (another free alternative)
# WEB3STORAGE_TOKEN=your_web3storage_token

# Local file storage fallback (always works, no IPFS needed)
# Files stored on server at: ./uploads/
LOCAL_STORAGE_PATH=./uploads

# === Database ===
DATABASE_URL=sqlite:///./ipchain.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/ipchain

# === JWT ===
JWT_SECRET=change-this-to-a-random-secret-string

# === Blockchain ===
CONTRACT_ADDRESS=0x_Your_Contract_Address_Here

# Polygon Mumbai Testnet
RPC_URL_MUMBAI=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet (production)
RPC_URL_POLYGON=https://polygon-rpc.com

# Wallet private key for contract deployment
PRIVATE_KEY=

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=

# === Stripe (optional - for credit card payments) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ETH_USD_RATE=3500
FRONTEND_URL=http://localhost:8000

# === Server ===
HOST=0.0.0.0
PORT=8000