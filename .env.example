# === Stripe (Fiat Payment On-Ramp) ===
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
ETH_USD_RATE=3500

# === Frontend URL (for Stripe redirect) ===
FRONTEND_URL=http://localhost:8000

# === Blockchain ===
# Polygon Mumbai Testnet
RPC_URL_MUMBAI=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet (for production)
RPC_URL_POLYGON=https://polygon-rpc.com

# Private key for contract deployment
PRIVATE_KEY=your_wallet_private_key

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Deployed contract address
CONTRACT_ADDRESS=0x_Your_Contract_Address_Here

# === IPFS (Pinata) ===
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# === Database ===
# SQLite (development)
DATABASE_URL=sqlite:///./ipchain.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/ipchain

# === JWT ===
JWT_SECRET=change-this-to-a-random-secret-key

# === Server ===
HOST=0.0.0.0
PORT=8000